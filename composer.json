{
    "name": "markmatusek74/reporting-engine",
    "description": "A comprehensive Laravel reporting engine package with Livewire 3.x components and dynamic report generation capabilities",
    "type": "library",
    "keywords": [
        "laravel",
        "reporting",
        "livewire",
        "mysql",
        "tailwind",
        "package"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Mark Matusek",
            "email": "markmatusek74@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0",
        "livewire/livewire": "^3.0",
        "illuminate/support": "^10.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "MarkMatusek74\\ReportingEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MarkMatusek74\\ReportingEngine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MarkMatusek74\\ReportingEngine\\ReportingEngineServiceProvider"
            ],
            "aliases": {
                "ReportingEngine": "MarkMatusek74\\ReportingEngine\\Facades\\ReportingEngine"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}